HTTPS_PORT=3780
T3_TARGET=http://127.0.0.1:3773
PUBLIC_URL=https://your-t3-host:3780
UPSTREAM_TIMEOUT_MS=15000
SSL_KEY_PATH=./key.pem
SSL_CERT_PATH=./cert.pem

# HTTP mode — use when running behind Tailscale Serve or another HTTPS reverse proxy.
# When enabled, the proxy skips TLS and listens on plain HTTP.
# Start with: node server.js --http
# PROXY_HTTP=true
# HTTP_PORT=3780
