{
  "env": {
    "node": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-implicit-globals": "error"
  },
  "overrides": [
    {
      "files": ["sw.js"],
      "env": {
        "serviceworker": true,
        "node": false
      },
      "rules": {
        "no-implicit-globals": "off"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "apk/",
    "harness-pages/"
  ]
}
